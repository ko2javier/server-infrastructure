# Database - Aiven MySQL
DB_URL=jdbc:mysql://your-aiven-host:port/weatherdb?useSSL=true&requireSSL=true&verifyServerCertificate=false&serverTimezone=UTC
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Redis - Railway
REDIS_URL=redis://default:your_password@your-railway-host:port

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars

# URLs internas entre servicios
API_SERVICE_URL=http://api-service:5000
AUTH_SERVICE_URL=http://auth-service:4000
GATEWAY_URL=http://gateway:7000
